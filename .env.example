# ---------------------------------------------------------------------------
# RWA Reliability Analyzer - environment
# Copy to .env.local and fill in. Everything except Supabase degrades
# gracefully when absent (assets drop to a lower coverage tier).
# ---------------------------------------------------------------------------

# On-chain RPC endpoints (Alchemy/Chainstack/etc). Per supported chain.
ETHEREUM_RPC_URL=
BASE_RPC_URL=
AVALANCHE_RPC_URL=

# OpenAI: document extraction of qualitative fields. Absent = qualitative
# fields resolve to unverifiable.
OPENAI_API_KEY=

# rwa.xyz official API (v4). Programmatic access is Enterprise/paid; the
# $0 plan is dashboard-only. Absent = reference fields skipped; qualitative
# data comes from the seed registry + LLM extraction.
RWA_XYZ_API_KEY=

# Optional web-search API for issuer-doc discovery on cold lookups.
# Absent = discovery falls back to the rwa.xyz disclosure URL only.
WEB_SEARCH_API_KEY=

# Supabase (the asset store + feature-request pipeline). Required for caching,
# seeding, and the suggestion box / triage / synthesis workers.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Guards the cron routes. The refresh cron fails OPEN if unset; the feature
# triage + cluster workers fail CLOSED (they spend the OpenAI budget). Vercel
# adds `Authorization: Bearer $CRON_SECRET` to cron calls automatically when set.
CRON_SECRET=
# Gates the maintainer-only demand view (/api/features/demand, /feature-requests/demand).
# Fails closed when unset. Pass as ?key= or the x-maintainer-key header.
MAINTAINER_KEY=

# Optional SEC EDGAR courtesy header (https://www.sec.gov/os/webmaster-faq#developers)
SEC_USER_AGENT=

# Public base URL (auto-detected on Vercel).
NEXT_PUBLIC_APP_URL=http://localhost:3000
